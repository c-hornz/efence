  Key code patterns used throughout

  Deterministic event_id (Wi-Fi):
  F.sha2(F.concat_ws("|",
      F.col("sensor_id"),
      F.unix_millis(F.col("event_time")).cast("string"),
      F.coalesce(F.col("bssid"), F.lit("__no_bssid__")),
      F.coalesce(F.col("message_id"), F.lit("__no_msg__")),
  ), 256)

  Deduplication within watermark (silver):
  dlt.read_stream("observations_bronze")
     .withWatermark("event_time", "2 hours")
     .dropDuplicatesWithinWatermark(["event_id"])
     .transform(_normalize_wifi)

  MAC hashing with secret salt:
  F.sha2(F.concat(
      F.lower(F.regexp_replace(F.col("bssid"), "[:\\-.]", "")),
      F.lit(MAC_HASH_SALT)   # from spark.conf / Databricks Secrets
  ), 256)

  Cross-pipeline streaming read (gold reading silver):
  spark.readStream.table("efence.wifi_silver.observations")
  # NOT dlt.read() — that only works within the same pipeline

  Stream-stream window join (co-presence):
  wifi_stream.join(
      bt_stream,
      on=(wifi["sensor_id"] == bt["sensor_id"])
       & wifi["wifi_event_time"].between(
           bt["bt_event_time"] - F.expr("INTERVAL 30 SECONDS"),
           bt["bt_event_time"] + F.expr("INTERVAL 30 SECONDS"),
       ),
      how="inner",
  )

